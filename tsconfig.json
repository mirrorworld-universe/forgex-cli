{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "paths": {
      "@/store": ["./src/shims/store.ts"],
      "@/store/*": ["./src/shims/store.ts"],
      "@/store/slices/*": ["./src/shims/store.ts"],
      "@cli/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
